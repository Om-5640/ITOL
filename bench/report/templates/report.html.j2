<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
/* ── Aurora design tokens (matching dashboard) ── */
:root {
  --radius: 12px;
  --transition: 0.25s ease;
  --font: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
:root[data-theme="dark"] {
  --bg-base:    #0A0A0F;
  --bg-card:    #13131A;
  --bg-glass:   rgba(20,22,32,0.62);
  --bg-input:   rgba(255,255,255,0.05);
  --text-primary: #E8E8F0;
  --text-secondary: rgba(232,232,240,0.55);
  --text-muted: rgba(232,232,240,0.35);
  --border:     rgba(255,255,255,0.08);
  --accent:     #7C6FFF;
  --accent-soft: rgba(124,111,255,0.12);
  --success:    #34D399;
  --warning:    #FBBF24;
  --danger:     #F87171;
  --green:      #10B981;
}
:root[data-theme="light"] {
  --bg-base:    #FAFAFB;
  --bg-card:    #FFFFFF;
  --bg-glass:   rgba(255,255,255,0.62);
  --bg-input:   rgba(0,0,0,0.04);
  --text-primary: #0F0F1A;
  --text-secondary: rgba(15,15,26,0.60);
  --text-muted: rgba(15,15,26,0.40);
  --border:     rgba(0,0,0,0.08);
  --accent:     #6B5FEE;
  --accent-soft: rgba(107,95,238,0.10);
  --success:    #059669;
  --warning:    #D97706;
  --danger:     #DC2626;
  --green:      #059669;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: var(--font);
  background: var(--bg-base);
  color: var(--text-primary);
  min-height: 100vh;
  line-height: 1.6;
}

/* Aurora background */
.aurora {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background: radial-gradient(ellipse 80% 60% at 20% 10%,  rgba(124,111,255,0.15) 0%, transparent 60%),
              radial-gradient(ellipse 60% 50% at 80% 20%,  rgba(52,211,153,0.10)  0%, transparent 55%),
              radial-gradient(ellipse 70% 40% at 50% 80%,  rgba(251,191,36,0.08)  0%, transparent 50%);
  filter: blur(40px) saturate(1.4);
  animation: aurora-drift 18s ease-in-out infinite alternate;
}
@keyframes aurora-drift {
  0%   { transform: rotate(0deg) scale(1); }
  50%  { transform: rotate(2deg) scale(1.04); }
  100% { transform: rotate(-1deg) scale(0.98); }
}

/* Layout */
.container { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 0 24px 80px; }

/* Header */
.report-header {
  padding: 48px 0 32px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 40px;
}
.report-header h1 { font-size: 2.2rem; font-weight: 700; margin-bottom: 8px; }
.report-meta { color: var(--text-secondary); font-size: 0.85rem; display: flex; gap: 24px; flex-wrap: wrap; }
.report-meta span { display: flex; align-items: center; gap: 6px; }

/* Theme toggle */
.theme-toggle {
  position: fixed; top: 20px; right: 24px; z-index: 100;
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 8px; padding: 8px 12px; cursor: pointer;
  color: var(--text-secondary); font-size: 0.8rem; transition: var(--transition);
}
.theme-toggle:hover { color: var(--text-primary); background: var(--bg-input); }

/* Executive Summary */
.exec-summary {
  background: linear-gradient(135deg, var(--accent-soft) 0%, transparent 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px;
  margin-bottom: 40px;
  backdrop-filter: blur(12px);
}
.exec-summary h2 { font-size: 1.4rem; margin-bottom: 24px; color: var(--text-primary); }
.big-numbers { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin-bottom: 24px; }
.big-num { text-align: center; }
.big-num .value { font-size: 3rem; font-weight: 800; color: var(--accent); line-height: 1; }
.big-num .label { font-size: 0.85rem; color: var(--text-secondary); margin-top: 6px; }
.big-num.quality .value { color: var(--success); }
.big-num.savings .value { color: var(--warning); }
.exec-oneliner {
  text-align: center; font-size: 1.05rem; color: var(--text-secondary);
  border-top: 1px solid var(--border); padding-top: 20px; margin-top: 8px;
}

/* Cards */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  margin-bottom: 24px;
  backdrop-filter: blur(8px);
}
.card h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: 16px; }
.card h4 { font-size: 0.95rem; font-weight: 600; margin-bottom: 12px; color: var(--text-secondary); }

/* Collapsible */
details > summary {
  cursor: pointer; font-weight: 600; font-size: 1.05rem;
  padding: 16px 20px; border-radius: var(--radius);
  background: var(--bg-card); border: 1px solid var(--border);
  list-style: none; display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 4px;
}
details > summary::after { content: "▾"; transition: var(--transition); }
details[open] > summary::after { transform: rotate(180deg); }
details .detail-body { padding: 20px; background: var(--bg-input); border-radius: 0 0 var(--radius) var(--radius); border: 1px solid var(--border); border-top: none; margin-bottom: 24px; }

/* Charts grid */
.charts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 20px; margin-top: 16px; }
.chart-wrap { background: var(--bg-input); border-radius: 8px; padding: 16px; }
.chart-wrap canvas { max-height: 240px; }
.chart-title { font-size: 0.82rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em; }

/* Stats row */
.stats-row { display: flex; gap: 20px; flex-wrap: wrap; margin: 16px 0; }
.stat-pill {
  background: var(--accent-soft); border-radius: 20px;
  padding: 6px 16px; font-size: 0.85rem; font-weight: 600; color: var(--accent);
}
.stat-pill.good { background: rgba(52,211,153,0.12); color: var(--success); }
.stat-pill.warn { background: rgba(251,191,36,0.12); color: var(--warning); }

/* Scale table */
.scale-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.scale-table th, .scale-table td { padding: 10px 14px; text-align: right; border-bottom: 1px solid var(--border); }
.scale-table th { color: var(--text-secondary); font-weight: 600; font-size: 0.78rem; text-transform: uppercase; }
.scale-table th:first-child, .scale-table td:first-child { text-align: left; }
.scale-table .saved { color: var(--success); font-weight: 600; }
.scale-table tr:hover td { background: var(--accent-soft); }

/* Sample cards */
.sample-card { border: 1px solid var(--border); border-radius: 8px; padding: 16px; margin-bottom: 12px; font-size: 0.83rem; }
.sample-card .sc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.sample-card .sc-badges { display: flex; gap: 6px; flex-wrap: wrap; }
.badge { padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; font-weight: 600; }
.badge-green  { background: rgba(52,211,153,0.15); color: var(--success); }
.badge-yellow { background: rgba(251,191,36,0.15); color: var(--warning); }
.badge-purple { background: var(--accent-soft); color: var(--accent); }
.badge-red    { background: rgba(248,113,113,0.15); color: var(--danger); }
.sc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 10px; }
.sc-col label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 4px; }
.sc-col pre { background: var(--bg-input); border-radius: 6px; padding: 8px; white-space: pre-wrap; word-break: break-word; font-family: "Fira Mono", monospace; font-size: 0.77rem; color: var(--text-secondary); max-height: 140px; overflow-y: auto; }

/* Limitations */
.limitations-list { list-style: none; }
.limitations-list li { padding: 10px 0; border-bottom: 1px solid var(--border); color: var(--text-secondary); font-size: 0.9rem; display: flex; gap: 10px; }
.limitations-list li::before { content: "⚠"; color: var(--warning); flex-shrink: 0; }

/* Provider table */
.prov-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.prov-table th, .prov-table td { padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border); }
.prov-table th { color: var(--text-secondary); font-weight: 600; font-size: 0.78rem; text-transform: uppercase; }

/* Smoke banner */
.smoke-banner {
  background: rgba(251,191,36,0.12); border: 1px solid var(--warning);
  border-radius: var(--radius); padding: 12px 20px; margin-bottom: 24px;
  color: var(--warning); font-size: 0.87rem;
}

/* Workload section header */
.section-header {
  display: flex; align-items: baseline; gap: 12px;
  margin-bottom: 16px; padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.section-header h2 { font-size: 1.3rem; }
.section-header .wl-desc { font-size: 0.85rem; color: var(--text-secondary); }

/* CI footnote */
.ci-note { font-size: 0.78rem; color: var(--text-muted); margin-top: 6px; }

/* Reproducibility */
.repro-box {
  background: var(--bg-input); border-radius: 8px; padding: 16px;
  font-family: "Fira Mono", monospace; font-size: 0.85rem;
  color: var(--success); margin-top: 12px;
}

footer { margin-top: 60px; padding: 24px 0; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.8rem; text-align: center; }
</style>
</head>
<body>
<div class="aurora"></div>

<button class="theme-toggle" onclick="document.documentElement.dataset.theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark'">
  ☀ / ☾ Theme
</button>

<div class="container">

<!-- Header -->
<header class="report-header">
  <h1>ITOL Benchmark Report</h1>
  <div class="report-meta">
    <span>📅 {{ generated_at }}</span>
    <span>🔖 git {{ git_sha }}</span>
    <span>🐍 Python {{ python_version }}</span>
    <span>📦 ITOL {{ itol_version }}</span>
    <span>🔬 n={{ n_total }} requests</span>
  </div>
</header>

{% if is_smoke %}
<div class="smoke-banner">
  ⚠ <strong>Smoke-test run</strong> — 5 samples/workload, MockProvider (no API keys).
  Numbers are illustrative; run <code>python -m bench run --providers groq,mistral,cohere --workloads all --n 150</code> for real measurements.
</div>
{% endif %}

{% if shortfalls %}
<div class="smoke-banner" style="background:rgba(248,113,113,0.12);border-color:var(--danger);color:var(--danger)">
  ⚠ <strong>Sample-size shortfall</strong> — {{ shortfalls|length }} workload/provider
  combination(s) did not reach the requested n={{ shortfall_requested_n }} successful samples
  (free-tier rate limits / daily quota). Confidence intervals on the affected rows are wider.
  Re-run the same command to retry failed samples.
  <ul style="margin:8px 0 0 18px;font-size:0.85rem">
    {% for sf in shortfalls %}
    <li>{{ sf.workload }} × {{ sf.provider }}: {{ sf.achieved }}/{{ sf.requested }} samples</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<!-- Executive Summary -->
<section class="exec-summary">
  <h2>Executive Summary</h2>
  <div class="big-numbers">
    <div class="big-num">
      <div class="value">{{ summary.token_reduction_pct }}%</div>
      <div class="label">Blended Token Reduction</div>
    </div>
    <div class="big-num savings">
      <div class="value">${{ "%.2f"|format(summary.cost_saved_usd) }}</div>
      <div class="label">Equivalent Cost Saved<br>(paid-tier pricing)</div>
    </div>
    <div class="big-num savings">
      <div class="value">{{ summary.cost_saved_pct }}%</div>
      <div class="label">Cost Reduction<br>(paid-tier equivalent)</div>
    </div>
    <div class="big-num quality">
      <div class="value">{{ summary.quality_parity }}</div>
      <div class="label">Avg Quality Parity<br>(1.0 = identical)</div>
    </div>
    <div class="big-num">
      <div class="value">{{ summary.n_workloads }}</div>
      <div class="label">Workloads × {{ summary.n_providers }} Providers</div>
    </div>
  </div>
  <div class="exec-oneliner">
    ITOL reduced token consumption by <strong>{{ summary.token_reduction_pct }}%</strong>
    across {{ summary.n_workloads }} workload types while maintaining a quality parity score of
    <strong>{{ summary.quality_parity }}</strong> (floor = 0.95) —
    measured on {{ summary.n_requests }} requests against free-tier LLM APIs.
  </div>
</section>

<!-- Methodology (collapsible) -->
<details>
  <summary>Methodology &amp; Disclosures</summary>
  <div class="detail-body">
    <div class="card" style="margin-bottom:16px">
      <h4>Providers &amp; Models</h4>
      <table class="prov-table">
        <thead><tr><th>Provider</th><th>Model</th><th>Input $/MTok</th><th>Output $/MTok</th><th>RPS limit</th></tr></thead>
        <tbody>
        {% for pc in provider_configs %}
        <tr>
          <td>{{ pc.name | capitalize }}</td>
          <td><code>{{ pc.model }}</code></td>
          <td>${{ pc.input_price_mtoken }}</td>
          <td>${{ pc.output_price_mtoken }}</td>
          <td>{{ pc.rps }}/s</td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
      <p style="margin-top:10px;font-size:0.82rem;color:var(--text-secondary)">
        Pricing source: provider websites, {{ generated_at[:7] }}.
        Cost figures use paid-tier pricing for representativeness; actual billed cost = $0 (free tiers used).
      </p>
    </div>
    <div class="card" style="margin-bottom:16px">
      <h4>Quality Scoring</h4>
      <p style="font-size:0.87rem;color:var(--text-secondary)">
        RAG: Exact Match + Token F1 against HotpotQA gold answers (EM primary, F1 fallback).<br>
        Agent: Entity coverage (correct entities in response) + Jaccard bigram overlap.<br>
        Chat &amp; FAQ: Jaccard bigram parity + length ratio + refusal-flag match.<br>
        LLM tiebreaker: Groq <code>llama-3.1-8b-instant</code> used when deterministic score ∈ [0.85, 0.95].
        Final score blended 70% deterministic + 30% LLM.
      </p>
    </div>
    <div class="card">
      <h4>Honest Disclosures</h4>
      <ul class="limitations-list">
        <li>None of the three free tiers support provider prompt caching.
            The Prefix-Stable Optimization benefit (up to 50% additional savings on OpenAI/Anthropic)
            is <strong>not included</strong> in these numbers.</li>
        <li>Temperature=0, seed=42 for reproducibility. Both baseline and ITOL run on identical prompts.</li>
        <li>Sample sizes: ~{{ n_per_combo }}/workload/provider
            (constrained by free-tier rate limits).</li>
        <li>Confidence intervals: 95% bootstrap, 1000 resamples on all aggregate figures.</li>
      </ul>
    </div>
  </div>
</details>

<!-- Per-workload sections -->
{% for section in workload_sections %}
<div class="card" style="margin-top:32px">
  <div class="section-header">
    <h2>{{ section.label }}</h2>
    <span class="wl-desc">{{ section.description }}</span>
  </div>

  {% for pp in section.per_provider %}
  {% set s = pp.stats %}
  {% set c = pp.chart %}

  <div style="margin-bottom:28px">
    <h4>Provider: {{ pp.provider | upper }}</h4>

    <div class="stats-row">
      <div class="stat-pill good">▼ {{ c.token_reduction | round(1) }}% tokens
        <small style="font-weight:400"> [{{ c.token_reduction_lo | round(1) }}–{{ c.token_reduction_hi | round(1) }}]</small>
      </div>
      <div class="stat-pill {% if s.quality_mean >= 0.95 %}good{% elif s.quality_mean >= 0.85 %}warn{% else %}{% endif %}">
        ✓ {{ c.quality_mean }} parity
        <small style="font-weight:400"> [{{ c.quality_lo }}–{{ c.quality_hi }}]</small>
      </div>
      {% if s.cache_hit_rate > 0 %}
      <div class="stat-pill">⚡ {{ (s.cache_hit_rate * 100) | round(1) }}% cache hits</div>
      {% endif %}
      <div class="stat-pill">n={{ s.n_itol }}</div>
    </div>
    <div class="ci-note">95% bootstrap CI shown in brackets • All metrics over {{ s.n_itol }} ITOL requests</div>

    <div class="charts-grid">
      <!-- Strategy Breakdown -->
      <div class="chart-wrap">
        <div class="chart-title">Strategy Activation Rate</div>
        <canvas id="chart_strat_{{ section.name }}_{{ pp.provider }}"></canvas>
      </div>

      <!-- Latency -->
      <div class="chart-wrap">
        <div class="chart-title">Latency Distribution (ms)</div>
        <canvas id="chart_lat_{{ section.name }}_{{ pp.provider }}"></canvas>
      </div>
    </div>

    <!-- Sample cards (first 5) -->
    {% if s.sample_cards %}
    <div style="margin-top:20px">
      <h4>Sample Comparisons (highest savings → lowest quality parity)</h4>
      {% for card in s.sample_cards[:5] %}
      <div class="sample-card">
        <div class="sc-header">
          <div class="sc-badges">
            {% for strat in card.strategies %}
            <span class="badge badge-purple">{{ strat }}</span>
            {% endfor %}
            <span class="badge badge-green">-{{ card.tokens_saved }} tokens</span>
            {% if card.quality_score is not none %}
            <span class="badge {% if card.quality_score >= 0.95 %}badge-green{% elif card.quality_score >= 0.85 %}badge-yellow{% else %}badge-red{% endif %}">
              QP={{ "%.3f"|format(card.quality_score) }}
            </span>
            {% endif %}
          </div>
          {% if card.gold_answer %}
          <span style="font-size:0.78rem;color:var(--text-muted)">Gold: {{ card.gold_answer[:60] }}</span>
          {% endif %}
        </div>
        <div class="sc-grid">
          <div class="sc-col">
            <label>Original Prompt (truncated)</label>
            <pre>{{ card.prompt_baseline[:300] }}</pre>
          </div>
          <div class="sc-col">
            <label>ITOL-Optimized Prompt</label>
            <pre>{{ card.prompt_itol[:300] }}</pre>
          </div>
          <div class="sc-col">
            <label>Baseline Response</label>
            <pre>{{ card.response_baseline[:300] }}</pre>
          </div>
          <div class="sc-col">
            <label>ITOL Response</label>
            <pre>{{ card.response_itol[:300] }}</pre>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

  </div>
  {% endfor %}
</div>
{% endfor %}

<!-- Scale Extrapolation -->
<div class="card" style="margin-top:32px">
  <h3>Cost at Scale (Monthly Equivalent)</h3>
  <p style="color:var(--text-secondary);font-size:0.87rem;margin-bottom:16px">
    Based on {{ summary.token_reduction_pct }}% blended token reduction.
    75% input / 25% output token split assumed. Monthly = daily × 30.
  </p>
  <table class="scale-table">
    <thead>
      <tr>
        <th>Tokens/Day</th>
        {% for pc in provider_configs %}
        <th colspan="3" style="text-align:center;border-left:1px solid var(--border)">
          {{ pc.name | capitalize }}
        </th>
        {% endfor %}
      </tr>
      <tr>
        <th></th>
        {% for pc in provider_configs %}
        <th style="border-left:1px solid var(--border)">Without</th>
        <th>With ITOL</th>
        <th>Saved</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
    {% for row in scale_rows %}
    <tr>
      <td><strong>{{ "{:,}".format(row.tokens_per_day) }}</strong></td>
      {% for pc in provider_configs %}
      {% set col = row[pc.name] %}
      <td style="border-left:1px solid var(--border)">${{ "{:,.2f}".format(col.without_usd) }}</td>
      <td>${{ "{:,.2f}".format(col.with_usd) }}</td>
      <td class="saved">${{ "{:,.2f}".format(col.saved_usd) }}</td>
      {% endfor %}
    </tr>
    {% endfor %}
    </tbody>
  </table>
  <p class="ci-note">
    {{ pricing_note }}
    Verify current pricing at provider websites before using for budget decisions.
  </p>
</div>

<!-- Honest Limitations -->
<div class="card" style="margin-top:32px">
  <h3>Honest Limitations</h3>
  <ul class="limitations-list">
    {% for lim in honest_limitations %}
    <li>{{ lim }}</li>
    {% endfor %}
  </ul>
</div>

<!-- Reproducibility -->
<details style="margin-top:24px">
  <summary>Reproducibility</summary>
  <div class="detail-body">
    <p style="font-size:0.87rem;color:var(--text-secondary);margin-bottom:12px">
      Reproduce this exact run with the following command (requires GROQ_API_KEY,
      MISTRAL_API_KEY, and COHERE_API_KEY environment variables):
    </p>
    <div class="repro-box">$ {{ reproduce_cmd }}</div>
    <div style="margin-top:16px;font-size:0.83rem;color:var(--text-secondary)">
      <strong>Environment:</strong> Python {{ python_version }} •
      ITOL {{ itol_version }} •
      git {{ git_sha }} •
      Generated {{ generated_at }}<br>
      Raw JSONL data: <code>data/bench_results/raw/</code><br>
      Full dependency list: <code>pyproject.toml [bench]</code>
    </div>
  </div>
</details>

<footer>
  ITOL Benchmark Report • Generated {{ generated_at }} • git {{ git_sha }}<br>
  Cost figures use paid-tier pricing for representativeness. Actual cost during benchmark = $0 (free tiers).
</footer>

</div><!-- /container -->

<script>
/* ── Chart.js initialization ── */
const ACCENT  = '#7C6FFF';
const SUCCESS = '#34D399';
const WARNING = '#FBBF24';
const MUTED   = 'rgba(232,232,240,0.35)';
const GRID    = 'rgba(255,255,255,0.06)';

Chart.defaults.color = 'rgba(232,232,240,0.6)';
Chart.defaults.borderColor = GRID;

function stratBar(id, labels, values) {
  const ctx = document.getElementById(id);
  if (!ctx || !labels.length) return;
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'Activation %',
        data: values,
        backgroundColor: [ACCENT, SUCCESS, WARNING, '#F87171', '#60A5FA', '#A78BFA', '#34D399'],
        borderRadius: 4,
      }]
    },
    options: {
      indexAxis: 'y',
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: GRID }, max: 100, ticks: { callback: v => v + '%' } },
        y: { grid: { display: false } }
      }
    }
  });
}

function latencyBar(id, baseline, itol) {
  const ctx = document.getElementById(id);
  if (!ctx) return;
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Baseline', 'ITOL'],
      datasets: [{
        label: 'Avg Latency (ms)',
        data: [baseline, itol],
        backgroundColor: [MUTED, ACCENT],
        borderRadius: 4,
      }]
    },
    options: {
      plugins: { legend: { display: false } },
      scales: {
        y: { grid: { color: GRID }, ticks: { callback: v => v + ' ms' } },
        x: { grid: { display: false } }
      }
    }
  });
}

/* Initialize all charts from inline data */
{% for section in workload_sections %}
{% for pp in section.per_provider %}
{% set c = pp.chart %}
stratBar(
  "chart_strat_{{ section.name }}_{{ pp.provider }}",
  {{ c.strategy_labels | tojson }},
  {{ c.strategy_values | tojson }}
);
latencyBar(
  "chart_lat_{{ section.name }}_{{ pp.provider }}",
  {{ c.latency_baseline }},
  {{ c.latency_itol }}
);
{% endfor %}
{% endfor %}
</script>
</body>
</html>
